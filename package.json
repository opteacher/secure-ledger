{
  "name": "secure-ledger",
  "version": "1.0.6",
  "description": "密钥终端 - 凭证管理与自动化登录平台",
  "main": "dist-electron/main.js",
  "homepage": "https://github.com/secure-ledger/secure-ledger",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build && electron-builder",
    "build:win": "node scripts/prepare-build.js win32 && vue-tsc --noEmit && vite build && electron-builder --win",
    "build:win7": "node scripts/prepare-build.js win32 --legacy && node win7-build/build.js",
    "build:linux": "node scripts/prepare-build.js linux && vue-tsc --noEmit && vite build && electron-builder --linux",
    "build:linux:deb": "node scripts/prepare-build.js linux && vue-tsc --noEmit && vite build && electron-builder --linux deb",
    "build:linux:tar": "node scripts/prepare-build.js linux && vue-tsc --noEmit && vite build && electron-builder --linux tar.gz",
    "build:mac": "node scripts/prepare-build.js darwin && vue-tsc --noEmit && vite build && electron-builder --mac",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "create-test-user": "ts-node scripts/create-test-user.ts",
    "test": "vitest run",
    "test:backend": "vitest run --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "test:e2e": "playwright test --config playwright.config.ts",
    "test:frontend": "vitest run --config vitest.config.frontend.ts",
    "test:frontend:coverage": "vitest run --config vitest.config.frontend.ts --coverage",
    "test:report": "node scripts/generate-test-report.js",
    "decrypt-db": "npx tsx scripts/decrypt-db.ts",
    "mock-server": "node mock-server/server.js",
    "mock-register": "node mock-server/register.js",
    "mock-setup": "npm run mock-server & npm run mock-register",
    "setup-python": "node scripts/setup-python-runtime.js"
  },
  "keywords": [
    "password-manager",
    "account-manager",
    "electron",
    "vue",
    "typescript"
  ],
  "author": "SecureLedger Team",
  "license": "MIT",
  "dependencies": {
    "extract-zip": "^2.0.1",
    "jose": "^5.2.0",
    "pinia": "^2.1.7",
    "puppeteer-core": "^22.0.0",
    "puppeteer-core-legacy": "npm:puppeteer-core@^13.7.0",
    "sharp": "^0.34.5",
    "sql.js": "^1.14.1",
    "ssh2": "^1.15.0",
    "tesseract.js": "^5.1.1",
    "uuid": "^9.0.0",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.11.17",
    "@types/sql.js": "^1.4.10",
    "@types/ssh2": "^1.15.0",
    "@types/uuid": "^9.0.0",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vitest/coverage-v8": "^4.1.8",
    "@vue/test-utils": "^2.4.10",
    "autoprefixer": "^10.4.17",
    "better-sqlite3": "^12.8.0",
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3",
    "jsdom": "^29.1.1",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vite": "^5.1.4",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^4.1.8",
    "vue-tsc": "^2.0.6",
    "xlsx": "^0.18.5"
  }
}
